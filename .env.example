# ============================================================================
# CNB Mobile — Environment variables
# ============================================================================
# Copy this file to `.env.local` and fill in real values.
# Anything prefixed with NEXT_PUBLIC_ is exposed to the browser bundle.
# ============================================================================

# ---- Firebase (waitlist) ----------------------------------------------------
# Same project as the mobile app (cnbmobile-2053c). Public web SDK config —
# safe to expose; security is enforced via Firestore rules on /leads.
# Get values at: https://console.firebase.google.com/project/cnbmobile-2053c
#   → Project Settings → Your apps → Web app → SDK setup and configuration
# If unset, the waitlist returns a graceful error and the site still builds.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=cnbmobile-2053c.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=cnbmobile-2053c
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=cnbmobile-2053c.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- CNB Token --------------------------------------------------------------
# Mint address of the CNB SPL token on Solana mainnet.
# Leave blank to display the "to be announced" placeholder.
NEXT_PUBLIC_CNB_MINT_ADDRESS=

# ---- Social links (footer) --------------------------------------------------
# Footer renders icons only for links that are set — empty values stay hidden.
# Replace with real handles extracted from cnbmobile.com.
NEXT_PUBLIC_TWITTER_URL=
NEXT_PUBLIC_TELEGRAM_URL=
NEXT_PUBLIC_DISCORD_URL=
NEXT_PUBLIC_GITHUB_URL=

# ---- App download links (optional) ------------------------------------------
# Wire these to the "Download App" CTAs once the app is in the stores.
NEXT_PUBLIC_APP_STORE_URL=
NEXT_PUBLIC_PLAY_STORE_URL=

# ---- PostHog (product analytics) --------------------------------------------
# Get the project API key from posthog.com → Project Settings → API Keys.
# If both vars are unset, PostHog is not initialized (graceful no-op).
# Host defaults to https://us.i.posthog.com — change to https://eu.i.posthog.com
# if your project lives on the EU cloud.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
